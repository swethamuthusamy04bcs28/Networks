#include <stdio.h>
#include <string.h>

int main()
{
    char str[100];
    int input[800];   // Stores binary bits (up to 100 characters * 8 bits)
    int output[1200]; // Stores bit-stuffed frame
    int destuffed[800]; // Stores recovered bits after destuffing
    int flag[8] = {0,1,1,1,1,1,1,0};
    int n = 0, i, j = 0, k;
    int count = 0;
    int stuffing = 0;

    printf("Enter the string: ");
    fgets(str, sizeof(str), stdin);
    str[strcspn(str, "\n")] = '\0';

    // 1. Convert string to ASCII and then to 8-bit Binary
    for(i = 0; str[i] != '\0'; i++)
    {
        int ascii = (int)str[i];
        for(k = 7; k >= 0; k--)
        {
            input[n++] = (ascii >> k) & 1;
        }
    }

    // 2. Bit Stuffing Process
    for(i = 0; i < n; i++)
    {
        output[j++] = input[i];

        if(input[i] == 1)
            count++;
        else
            count = 0;

        if(count == 5)
        {
            output[j++] = 0; // Insert 0
            stuffing = 1;
            count = 0;       // Reset counter after stuffing
        }
    }

    // Print Original Binary Data
    printf("\nOriginal Bit Stream : ");
    for(i = 0; i < n; i++)
        printf("%d", input[i]);

    // Print Final Transmitted Frame
    printf("\n\nTransmitted Frame   : ");
    for(i = 0; i < 8; i++) printf("%d", flag[i]); // Start Flag
    for(i = 0; i < j; i++) printf("%d", output[i]); // Data
    for(i = 0; i < 8; i++) printf("%d", flag[i]); // End Flag

    if(stuffing)
        printf("\n\nBit Stuffing Performed.");
    else
        printf("\n\nNo Bit Stuffing Required.");


    // 3. Bit Destuffing Process (Reversing the process on 'output' array)
    int destuffed_idx = 0;
    count = 0;

    for(i = 0; i < j; i++)
    {
        destuffed[destuffed_idx++] = output[i];

        if(output[i] == 1)
            count++;
        else
            count = 0;

        // If five 1s are encountered, skip the next bit (which is the stuffed 0)
        if(count == 5)
        {
            i++; // Skip the next index containing the stuffed 0
            count = 0; // Reset counter
        }
    }

    // Print Destuffed Bit Stream
    printf("\n\nDestuffed Bit Stream: ");
    for(i = 0; i < destuffed_idx; i++)
        printf("%d", destuffed[i]);

    // 4. Convert Destuffed Binary back to Text String
    char recovered_str[100];
    int char_idx = 0;

    for(i = 0; i < destuffed_idx; i += 8)
    {
        int ascii_val = 0;
        for(k = 0; k < 8; k++)
        {
            ascii_val = (ascii_val << 1) | destuffed[i + k];
        }
        recovered_str[char_idx++] = (char)ascii_val;
    }
    recovered_str[char_idx] = '\0'; // Null-terminate the string

    printf("\nRecovered String    : %s\n", recovered_str);

    return 0;
}
